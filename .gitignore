/target
**/*.rs.bk

# Working docs — local only, never committed (see CLAUDE.md)
/md/

# Secrets
/.env

# Model artifacts — large binaries, never committed (dir or symlink)
/models/
/models

# Tailwind standalone CLI binary — vendored locally, not committed (~114M)
crates/drgtw-ui/styles/tailwindcss

# Live local config (use drgtw.toml.example as template)
/drgtw.toml

# Runtime trace output (see [tracing] in docs/config-reference.md)
traces/

# Project instructions — local only
/CLAUDE.md

# Local demo overrides (internal resource names)
demo/*.local.toml
demo/compose.override.yml

# Tailwind standalone CLI (build tool, platform-specific binary)
crates/drgtw-ui/tailwindcss
